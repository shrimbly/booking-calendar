# The shared PIN family members use to enter the calendar.
FAMILY_PIN=1234

# Optional database. Without this, the app runs against demo data in src/lib/data.ts.
DATABASE_URL=

# Optional image uploads for profile pictures and stay photos.
# Create a Vercel Blob store, then copy the read/write token here.
BLOB_READ_WRITE_TOKEN=

# Optional stay-cost prompt. If BOOKING_COST_PER_NIGHT is set, new bookings
# show a payment dialog before confirmation.
BOOKING_COST_PER_NIGHT=
BOOKING_COST_CURRENCY=NZD
PAYMENT_ACCOUNT_NAME=
PAYMENT_ACCOUNT_NUMBER=
PAYMENT_REFERENCE=
PAYMENT_NOTE=

# Mary mode admin identities. Use comma-separated person IDs from your people
# table. Defaults to "mary" when omitted.
MARY_IDS=mary

# Public site copy. These are safe to expose to the browser.
NEXT_PUBLIC_HOME_NAME="Book the lakehouse"
NEXT_PUBLIC_HOME_KIND=lakehouse
NEXT_PUBLIC_BUILT_BY=Willie
NEXT_PUBLIC_SITE_DESCRIPTION="A private family booking calendar for the lakehouse."
NEXT_PUBLIC_FOOTER_TEXT="Book the lakehouse · built by Willie"
NEXT_PUBLIC_REPO_URL="https://github.com/shrimbly/book-the-lakehouse"
NEXT_PUBLIC_HOME_SLUG=book-the-lakehouse

# Optional server-side cookie prefix. Use this when hosting multiple copies
# on the same domain, or leave blank to derive it from NEXT_PUBLIC_HOME_SLUG.
COOKIE_PREFIX=book-the-lakehouse
