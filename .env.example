# The shared PIN family members use to enter the calendar.
FAMILY_PIN=1234

# Optional database. Without this, the app runs against demo data in src/lib/data.ts.
DATABASE_URL=

# Optional image uploads for profile pictures and stay photos.
# Create a Vercel Blob store, then copy the read/write token here.
BLOB_READ_WRITE_TOKEN=

# Public site copy. These are safe to expose to the browser.
NEXT_PUBLIC_HOME_NAME="Kuratau Bach"
NEXT_PUBLIC_HOME_KIND=bach
NEXT_PUBLIC_BUILT_BY=Willie
NEXT_PUBLIC_SITE_DESCRIPTION="Family booking calendar for Kuratau Bach."
NEXT_PUBLIC_FOOTER_TEXT="Book the bach · built by Willie"
NEXT_PUBLIC_HOME_SLUG=kuratau

# Optional server-side cookie prefix. Use this when hosting multiple copies
# on the same domain, or leave blank to derive it from NEXT_PUBLIC_HOME_SLUG.
COOKIE_PREFIX=kuratau
